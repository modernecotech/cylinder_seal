# CylinderSeal Environment Configuration
# Copy this file to .env and fill in actual values

# Environment
ENVIRONMENT=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cylinder_seal
DB_USER=postgres
DB_PASSWORD=password
DB_MAX_CONNECTIONS=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Server
GRPC_PORT=50051
HTTP_PORT=8080
NODE_ID=node-1

# Logging
RUST_LOG=debug

# Crypto (KYC) - Phase 2
# KYC_PROVIDER=smile_identity
# SMILE_IDENTITY_KEY=...
# SMILE_IDENTITY_SECRET=...
