# CylinderSeal Environment Configuration
# Copy this file to .env and fill in actual values for your deployment

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================
# Options: development, staging, production
ENVIRONMENT=development

# ============================================================================
# POSTGRESQL DATABASE
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cylinder_seal
DB_USER=postgres
DB_PASSWORD=password
DB_MAX_CONNECTIONS=10

# ============================================================================
# REDIS CACHE & SESSION STORE
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# SERVER & GRPC
# ============================================================================
# Super-peer gRPC server port (device ↔ super-peer communication)
GRPC_PORT=50051

# REST API server port (admin, webhooks, fiat integrations)
HTTP_PORT=8080

# Unique identifier for this super-peer node
NODE_ID=node-1

# ============================================================================
# BYZANTINE CONSENSUS (Super-Peer Cluster)
# ============================================================================
# Number of super-peers in the consensus quorum (typically 5 for production)
SUPER_PEER_QUORUM_SIZE=5

# Minimum confirmations required (typically 3 of 5 for Byzantine fault tolerance)
SUPER_PEER_MIN_CONFIRMATIONS=3

# Automatic device key rotation interval (days)
KEY_ROTATION_DAYS=30

# ============================================================================
# LOGGING
# ============================================================================
# Log level: TRACE, DEBUG, INFO, WARN, ERROR
RUST_LOG=info

# Use JSON structured logging (true) or human-readable format (false)
LOG_JSON=false

# ============================================================================
# INTEGRATIONS (PHASE 2 - OPTIONAL)
# ============================================================================

# KYC/Identity Verification (Smile Identity)
# KYC_PROVIDER=smile_identity
# SMILE_IDENTITY_KEY=...
# SMILE_IDENTITY_SECRET=...

# Fiat On-Ramps (Flutterwave, Wise, M-Pesa)
# FLUTTERWAVE_API_KEY=...
# WISE_API_KEY=...
# MPESA_API_KEY=...

# Currency Rate Feeds
# FOREX_API_KEY=...
# FOREX_PROVIDER=fixer_io
