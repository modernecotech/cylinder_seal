# Copy to /etc/cylinder-seal-pos.env and edit for the specific terminal.

POS_MERCHANT_NAME="Baghdad Grocer, Karrada"
POS_SUPER_PEER_URL="https://sp-baghdad.cbi.iq:50051"
POS_CURRENCY="IQD"
POS_SQLITE_PATH="/var/lib/cylinder-seal-pos/pos.db"

# Transports: flip off any that this terminal doesn't have.
POS_ENABLE_NFC=true
POS_ENABLE_BLE=true
POS_ENABLE_CAMERA=true
POS_CAMERA_INDEX=0

# Receipt printer — "disabled" | "usb" | "serial" | "network".
POS_PRINTER_KIND=disabled
POS_PRINTER_TARGET=/dev/usb/lp0
POS_PRINTER_WIDTH=32

# Tracing — "info" for production, "debug,cs_pos=trace" for diagnostics.
RUST_LOG=info
